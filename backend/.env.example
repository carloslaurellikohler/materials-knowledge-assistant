# Copie este arquivo para .env e preencha os valores reais
# O .env NUNCA deve ser commitado no git

OPENAI_API_KEY=sk-...
COHERE_API_KEY=...

# Gerado com: python3 -c "import secrets; print(secrets.token_hex(32))"
CLERK_JWT_SECRET=troque-por-uma-string-segura-de-32-chars

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://mka:mka-dev-password@localhost:5432/mka

# Supabase Storage
# IMPORTANTE: SUPABASE_KEY deve ser a chave "service_role" (secret), NÃO a "anon".
# O backend faz a autorização via Clerk e atua como cliente confiável que ignora RLS;
# usar a anon key resulta em 403 "new row violates row-level security policy" nos uploads.
# Onde encontrar: Supabase Dashboard → Project Settings → API → seção "Project API keys" → service_role.
# NUNCA exponha esta chave no frontend ou em repositórios públicos.
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_KEY=eyJhbGciOi...service_role-secret-key...
SUPABASE_BUCKET=mka-documents
