# Copie este arquivo para .env e preencha os valores reais
# O .env NUNCA deve ser commitado no git
#
# Domínio de produção de referência: mka.lk-tech-solution.com
# (em dev, o frontend roda em http://localhost:3000)
#
# Observação: QDRANT_URL, REDIS_URL e DATABASE_URL NÃO entram aqui — são
# definidas diretamente pelo docker-compose (apontando para os serviços da rede
# interna). Aqui você só define POSTGRES_PASSWORD, que o compose injeta na URL.

# =============================================================================
# OpenAI
# =============================================================================
# Chave obrigatória.
OPENAI_API_KEY=sk-...

# Modelo de chat. O DEFAULT do código (gpt-5.4) é um placeholder e pode não
# existir na sua conta — defina um modelo válido em produção.
OPENAI_CHAT_MODEL=gpt-4.1

# (Opcional) Os demais modelos têm defaults sensatos; só sobrescreva se precisar.
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small   # deve casar com QDRANT_VECTOR_SIZE
# OPENAI_VISION_MODEL=gpt-4o                       # usado só se OCR_BACKEND=vision
# OPENAI_WHISPER_MODEL=whisper-1

# =============================================================================
# Cohere (opcional — re-ranking; sem ela o sistema funciona sem reranking)
# =============================================================================
COHERE_API_KEY=

# =============================================================================
# Clerk — backend (validação dos JWTs)
# =============================================================================
# CLERK_JWKS_URL: Clerk Dashboard → Configure → API Keys → "JWKS URL"
#   Formato dev:  https://seu-app.clerk.accounts.dev/.well-known/jwks.json
#   Formato prod: https://clerk.lk-tech-solution.com/.well-known/jwks.json
CLERK_JWKS_URL=

# Usado apenas localmente sem CLERK_JWKS_URL (dev/test com HS256).
# Em produção, com JWKS preenchido, este valor é irrelevante.
CLERK_JWT_SECRET=dev-secret

# =============================================================================
# PostgreSQL
# =============================================================================
# Senha do banco relacional (usada pelo docker-compose). Os PDFs enviados pelos
# usuários também são persistidos no Postgres (tabela document_blobs), então use
# uma senha forte em produção (ex.: openssl rand -base64 24).
POSTGRES_PASSWORD=mka-dev-password

# =============================================================================
# CORS — origins permitidas pelo backend (separadas por vírgula)
# =============================================================================
# Dev:  http://localhost:3000,http://127.0.0.1:3000
# Prod: inclua o domínio público do frontend, ex.: https://mka.lk-tech-solution.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# =============================================================================
# Clerk — frontend (Next.js)
# =============================================================================
# ATENÇÃO: NEXT_PUBLIC_* são "assadas" (inlined) no `next build`. O Dockerfile do
# frontend as recebe como build args via docker-compose, então estes valores
# precisam estar definidos ANTES de `docker compose ... up --build`. Trocar a
# chave ou o flag depois exige rebuild do frontend (não basta restart).
NEXT_PUBLIC_ENABLE_CLERK=false
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY é server-side (runtime) no frontend.
CLERK_SECRET_KEY=

# =============================================================================
# Ajustes opcionais (têm defaults; só descomente para sobrescrever)
# =============================================================================
# Limite de upload de PDF em MB (alinhe com client_max_body_size do nginx).
# MAX_UPLOAD_MB=100
# OCR para PDFs escaneados: "none" (default) ou "vision" (usa OPENAI_VISION_MODEL).
# OCR_BACKEND=none
