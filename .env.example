# Copie este arquivo para .env e preencha os valores reais
# O .env NUNCA deve ser commitado no git

# --- OpenAI ---
OPENAI_API_KEY=sk-...

# --- Cohere (opcional — re-ranking; sem ela o sistema funciona sem reranking) ---
COHERE_API_KEY=

# --- Clerk (autenticação) ---
# CLERK_JWKS_URL: Clerk Dashboard → Configure → API Keys → "JWKS URL"
# Formato dev:  https://seu-app.clerk.accounts.dev/.well-known/jwks.json
# Formato prod: https://clerk.seu-dominio.com/.well-known/jwks.json
CLERK_JWKS_URL=

# Usado apenas localmente sem CLERK_JWKS_URL (dev/test com HS256)
CLERK_JWT_SECRET=dev-secret

# --- PostgreSQL ---
# Senha do banco relacional (usada pelo docker-compose)
POSTGRES_PASSWORD=mka-dev-password

# --- CORS ---
# Lista de origins permitidas pelo backend, separadas por vírgula.
# Em produção, inclua o domínio público do frontend (ex.: https://app.exemplo.com).
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Supabase Storage (persistência de arquivos PDF) ---
# IMPORTANTE: SUPABASE_KEY deve ser a chave "service_role" (secret), NÃO a "anon".
# O backend faz a autorização via Clerk e atua como cliente confiável que ignora RLS;
# usar a anon key resulta em 403 "new row violates row-level security policy" nos uploads.
# Onde encontrar: Supabase Dashboard → Project Settings → API → seção "Project API keys" → service_role.
# NUNCA exponha esta chave no frontend ou em repositórios públicos.
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_KEY=eyJhbGciOi...service_role-secret-key...
SUPABASE_BUCKET=mka-documents
